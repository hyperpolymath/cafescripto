#
# CafeScripto face. Distinctive features exercised: `#` line comments,
# `###` block comments, paren-arrow `(args) -> body`, bare-arrow `-> body`,
# Yes/No/On/Off literal aliases.
# face: cafescripto

effect IO {
  fn println(s: String) -> ();
}

fn main() -{IO}-> () {
  let greeting = "Hello, CafeScripto!";
  let ready = Yes;
  println(greeting);
}
